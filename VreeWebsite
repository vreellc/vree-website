<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VREE — Clinical-grade performance. Physician-led.</title>
<meta name="description" content="VREE is a physician-led telehealth practice built for high-achieving students. Clinical-grade performance optimization. Launching soon.">
<meta property="og:title" content="VREE — Clinical-grade performance. Physician-led.">
<meta property="og:description" content="Physician-led performance optimization for high-achieving students. Launching soon at vree.md">
<meta property="og:type" content="website">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --navy:      #1B2A4A;
    --lnavy:     #2E4A7A;
    --vellum:    #F5F0E8;
    --champagne: #C9B882;
    --gold:      #8B7536;
    --white:     #FFFFFF;
    --lgray:     rgba(245,240,232,0.45);
  }

  html { height: 100%; }

  body {
    min-height: 100%;
    background: var(--navy);
    color: var(--vellum);
    font-family: 'Cormorant Garamond', Georgia, serif;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
    position: relative;
  }

  /* ── BACKGROUND TEXTURE ── */
  body::before {
    content: '';
    position: fixed; inset: 0; z-index: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% -10%, rgba(46,74,122,0.6) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 90% 90%, rgba(201,184,130,0.06) 0%, transparent 60%),
      radial-gradient(ellipse 30% 50% at 5% 60%, rgba(27,42,74,0.8) 0%, transparent 70%);
    pointer-events: none;
  }

  /* Fine grain overlay */
  body::after {
    content: '';
    position: fixed; inset: 0; z-index: 1;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    opacity: 0.4;
    pointer-events: none;
  }

  /* ── LAYOUT ── */
  .page {
    position: relative; z-index: 2;
    min-height: 100vh;
    display: flex; flex-direction: column;
    padding: 0 clamp(24px, 5vw, 80px);
  }

  /* ── NAV ── */
  nav {
    display: flex; justify-content: space-between; align-items: center;
    padding: 32px 0 0;
    opacity: 0;
    animation: fadeDown 0.8s ease 0.1s forwards;
  }

  .nav-mark {
    display: flex; align-items: center; gap: 14px;
  }

  /* V Mark SVG */
  .v-mark {
    width: 36px; height: 32px; flex-shrink: 0;
  }

  .nav-wordmark {
    font-family: 'DM Mono', monospace;
    font-size: 18px; font-weight: 500;
    letter-spacing: 0.25em;
    color: var(--vellum);
    text-transform: uppercase;
  }

  .nav-right {
    font-family: 'DM Mono', monospace;
    font-size: 10px; font-weight: 300;
    letter-spacing: 0.25em; text-transform: uppercase;
    color: rgba(201,184,130,0.5);
  }

  /* ── HERO ── */
  .hero {
    flex: 1;
    display: flex; flex-direction: column;
    justify-content: center;
    padding: clamp(60px, 10vh, 120px) 0 clamp(40px, 6vh, 80px);
    max-width: 900px;
  }

  .hero-eyebrow {
    font-family: 'DM Mono', monospace;
    font-size: clamp(9px, 1.2vw, 11px);
    font-weight: 300; letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--champagne);
    margin-bottom: 36px;
    display: flex; align-items: center; gap: 16px;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.3s forwards;
  }

  .hero-eyebrow::before {
    content: '';
    width: 32px; height: 1px;
    background: var(--champagne);
    opacity: 0.5;
  }

  .hero-title {
    font-size: clamp(52px, 8vw, 108px);
    font-weight: 300; line-height: 0.92;
    letter-spacing: -0.025em;
    color: var(--vellum);
    margin-bottom: 32px;
    opacity: 0;
    animation: fadeUp 1s ease 0.5s forwards;
  }

  .hero-title em {
    font-style: italic;
    color: var(--champagne);
  }

  .hero-subtitle {
    font-size: clamp(16px, 2.2vw, 22px);
    font-weight: 300; line-height: 1.7;
    color: rgba(245,240,232,0.6);
    max-width: 560px;
    margin-bottom: 56px;
    opacity: 0;
    animation: fadeUp 1s ease 0.7s forwards;
  }

  /* ── EMAIL FORM ── */
  .form-wrap {
    opacity: 0;
    animation: fadeUp 1s ease 0.9s forwards;
  }

  .form-label {
    font-family: 'DM Mono', monospace;
    font-size: 9px; font-weight: 300;
    letter-spacing: 0.3em; text-transform: uppercase;
    color: rgba(201,184,130,0.6);
    margin-bottom: 14px;
    display: block;
  }

  .form-row {
    display: flex;
    gap: 0;
    max-width: 480px;
    border: 1px solid rgba(201,184,130,0.25);
    transition: border-color 0.3s ease;
  }

  .form-row:focus-within {
    border-color: rgba(201,184,130,0.6);
  }

  .form-input {
    flex: 1;
    background: rgba(27,42,74,0.4);
    border: none; outline: none;
    padding: 14px 20px;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 16px; font-weight: 300;
    color: var(--vellum);
    letter-spacing: 0.02em;
  }

  .form-input::placeholder {
    color: rgba(245,240,232,0.25);
    font-style: italic;
  }

  .form-btn {
    background: var(--champagne);
    border: none; outline: none;
    padding: 14px 28px;
    font-family: 'DM Mono', monospace;
    font-size: 10px; font-weight: 400;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--navy);
    cursor: pointer;
    transition: background 0.2s ease;
    white-space: nowrap;
  }

  .form-btn:hover { background: #D4C494; }
  .form-btn:active { background: #B8A870; }

  .form-note {
    font-family: 'DM Mono', monospace;
    font-size: 9px; font-weight: 300;
    letter-spacing: 0.15em;
    color: rgba(245,240,232,0.2);
    margin-top: 12px;
    display: block;
  }

  /* Success state */
  .form-success {
    display: none;
    font-size: 16px; font-weight: 300;
    color: var(--champagne);
    font-style: italic;
    padding: 14px 0;
  }

  /* ── PILLARS ── */
  .pillars {
    display: flex; gap: 0;
    border-top: 1px solid rgba(201,184,130,0.12);
    opacity: 0;
    animation: fadeUp 1s ease 1.1s forwards;
  }

  .pillar {
    flex: 1;
    padding: clamp(24px, 3vw, 40px) 0;
    border-right: 1px solid rgba(201,184,130,0.08);
    padding-right: clamp(16px, 2.5vw, 36px);
    padding-left: clamp(16px, 2.5vw, 36px);
  }

  .pillar:first-child { padding-left: 0; }
  .pillar:last-child { border-right: none; padding-right: 0; }

  .pillar-letter {
    font-family: 'DM Mono', monospace;
    font-size: 10px; font-weight: 500;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--champagne);
    margin-bottom: 6px;
    display: block;
  }

  .pillar-name {
    font-size: clamp(14px, 1.8vw, 18px);
    font-weight: 300;
    color: var(--vellum);
    margin-bottom: 4px;
  }

  .pillar-desc {
    font-family: 'DM Mono', monospace;
    font-size: clamp(8px, 0.9vw, 10px);
    font-weight: 300; letter-spacing: 0.1em;
    color: rgba(245,240,232,0.3);
    text-transform: uppercase;
    line-height: 1.6;
  }

  /* ── FOOTER ── */
  footer {
    position: relative; z-index: 2;
    padding: 28px clamp(24px, 5vw, 80px);
    display: flex; justify-content: space-between; align-items: center;
    border-top: 1px solid rgba(201,184,130,0.08);
    opacity: 0;
    animation: fadeUp 0.8s ease 1.3s forwards;
  }

  .footer-left {
    font-family: 'DM Mono', monospace;
    font-size: 9px; font-weight: 300;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: rgba(245,240,232,0.2);
  }

  .footer-right {
    font-family: 'DM Mono', monospace;
    font-size: 9px; font-weight: 300;
    letter-spacing: 0.15em; text-transform: uppercase;
    color: rgba(245,240,232,0.2);
  }

  /* ── DECORATIVE LINE ── */
  .deco-line {
    position: fixed;
    right: clamp(24px, 5vw, 80px);
    top: 50%; transform: translateY(-50%);
    display: flex; flex-direction: column;
    align-items: center; gap: 10px;
    z-index: 3;
    opacity: 0;
    animation: fadeIn 1s ease 1.5s forwards;
  }

  .deco-dot {
    width: 4px; height: 4px; border-radius: 50%;
    background: rgba(201,184,130,0.4);
  }

  .deco-dot.active {
    background: var(--champagne);
    box-shadow: 0 0 8px rgba(201,184,130,0.4);
  }

  .deco-rule {
    width: 1px; height: 60px;
    background: linear-gradient(to bottom, rgba(201,184,130,0.3), transparent);
  }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeDown {
    from { opacity: 0; transform: translateY(-10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* ── MOBILE ── */
  @media (max-width: 640px) {
    .nav-right { display: none; }
    .deco-line { display: none; }

    .pillars { flex-direction: column; gap: 0; }
    .pillar {
      border-right: none;
      border-bottom: 1px solid rgba(201,184,130,0.08);
      padding: 20px 0;
    }
    .pillar:first-child { padding-left: 0; }
    .pillar:last-child { border-bottom: none; }

    .form-row { flex-direction: column; }
    .form-btn { padding: 14px; text-align: center; }

    footer { flex-direction: column; gap: 8px; text-align: center; }
  }

  @media (max-width: 480px) {
    .hero-title { letter-spacing: -0.02em; }
  }
</style>
</head>
<body>

<div class="page">

  <!-- NAV -->
  <nav>
    <div class="nav-mark">
      <!-- V Mark SVG — Concept 05 geometry -->
      <svg class="v-mark" viewBox="0 0 40 36" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0 0 L14 0 L20 10 L26 0 L40 0 L20 36 Z" fill="#F5F0E8"/>
        <path d="M11 0 L20 16 L29 0 L26 0 L20 10 L14 0 Z" fill="#1B2A4A"/>
      </svg>
      <span class="nav-wordmark">VREE</span>
    </div>
    <span class="nav-right">Launching 2026</span>
  </nav>

  <!-- HERO -->
  <div class="hero">
    <span class="hero-eyebrow">Physician-Led Performance Optimization</span>

    <h1 class="hero-title">
      Your biology.<br><em>Optimized.</em>
    </h1>

    <p class="hero-subtitle">
      VREE is a telehealth medical practice built for high-achieving students. Clinical-grade protocols. A licensed physician in your corner. Performance is not a supplement. It is a clinical decision.
    </p>

    <div class="form-wrap">
      <span class="form-label">Join the waitlist — be first when we launch</span>
      <div class="form-row" id="formRow">
        <input
          class="form-input"
          type="email"
          id="emailInput"
          placeholder="your@email.com"
          autocomplete="email"
        >
        <button class="form-btn" onclick="handleSubmit()">Notify Me</button>
      </div>
      <div class="form-success" id="formSuccess">
        You are on the list. We will be in touch. — VREE
      </div>
      <span class="form-note">No spam. One email when we launch. Unsubscribe anytime.</span>
    </div>
  </div>

  <!-- FOUR PILLARS -->
  <div class="pillars">
    <div class="pillar">
      <span class="pillar-letter">V</span>
      <div class="pillar-name">Vitality</div>
      <div class="pillar-desc">Cellular energy<br>& baseline</div>
    </div>
    <div class="pillar">
      <span class="pillar-letter">R</span>
      <div class="pillar-name">Resilience</div>
      <div class="pillar-desc">Sleep architecture<br>& recovery</div>
    </div>
    <div class="pillar">
      <span class="pillar-letter">E</span>
      <div class="pillar-name">Efficiency</div>
      <div class="pillar-desc">Cognitive load<br>& focus</div>
    </div>
    <div class="pillar">
      <span class="pillar-letter">E</span>
      <div class="pillar-name">Execution</div>
      <div class="pillar-desc">Goals, calendar<br>& protocols</div>
    </div>
  </div>

</div>

<!-- FOOTER -->
<footer>
  <span class="footer-left">VREE LLC &nbsp;·&nbsp; Parkland, Florida &nbsp;·&nbsp; vree.md</span>
  <span class="footer-right">© 2026 VREE LLC &nbsp;·&nbsp; All rights reserved</span>
</footer>

<!-- DECORATIVE SIDE ELEMENT -->
<div class="deco-line">
  <div class="deco-dot active"></div>
  <div class="deco-dot"></div>
  <div class="deco-dot"></div>
  <div class="deco-rule"></div>
</div>

<script>
function handleSubmit() {
  const input = document.getElementById('emailInput');
  const formRow = document.getElementById('formRow');
  const success = document.getElementById('formSuccess');
  const email = input.value.trim();

  // Basic validation
  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  if (!emailRegex.test(email)) {
    input.style.borderLeft = '2px solid rgba(239,83,80,0.6)';
    input.placeholder = 'Please enter a valid email';
    input.value = '';
    setTimeout(() => {
      input.style.borderLeft = 'none';
      input.placeholder = 'your@email.com';
    }, 2000);
    return;
  }

  // Success state
  formRow.style.display = 'none';
  success.style.display = 'block';

  // In production: send email to your backend or Mailchimp/ConvertKit API
  console.log('Waitlist signup:', email);
}

// Allow Enter key to submit
document.addEventListener('DOMContentLoaded', function() {
  const input = document.getElementById('emailInput');
  if (input) {
    input.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') handleSubmit();
    });
  }
});
</script>

</body>
</html>
